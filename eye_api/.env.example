# ─────────────────────────────────────────────────────────────
# eye_api/.env.example
# Copy to eye_api/.env and fill in your values
# ─────────────────────────────────────────────────────────────

# Firebase Web API Key (from Firebase Console → Project Settings → General)
FIREBASE_WEB_API_KEY=your_web_api_key_here

# Firebase Project ID (from Firebase Console → Project Settings → General)
FIREBASE_PROJECT_ID=your_project_id_here

# CORS Allowed Origins — comma-separated list of frontend URLs allowed to call the API
# Use * to allow all (fine for local dev, restrict this in production)
# Example: https://myapp.onrender.com,https://mycustomdomain.com
ALLOWED_ORIGINS=*


